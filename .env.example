# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/mern-ecommerce

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRE=7d
JWT_REFRESH_SECRET=your_super_secret_refresh_key_change_this
JWT_REFRESH_EXPIRE=30d

# Server Configuration
PORT=5000
NODE_ENV=development

# Local Storage Configuration
STORAGE_DRIVER=local
LOCAL_UPLOAD_DIR=backend/public/uploads
MEDIA_BASE_URL=http://localhost:5000

# Frontend Configuration
VITE_API_BASE_URL=http://localhost:5000/api

# Email Configuration (optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password

# Stripe (optional for payment)
STRIPE_SECRET_KEY=sk_test_your_stripe_key
STRIPE_PUBLIC_KEY=pk_test_your_stripe_key

# Store Configuration
STORE_NAME=My eCommerce Store
STORE_CURRENCY=PKR
STORE_TIMEZONE=Asia/Karachi
